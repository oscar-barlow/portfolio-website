<!doctype html>
<html lang="{{ site.locale }}">
  <head>
    {% render "head", metadata: site.metadata, title: data.title, description: data.description %}
  </head>
  <body class="{{ data.layout }} {{ data.page_class }}">
    {% render "navbar", metadata: site.metadata, resource: resource %}
    
    <div class="content-page">
      <main class="content-main">
        <div class="page-header">
          {% render 'page_header', title: 'Writing' %}
        </div>
        <div class="writing-subscribe">
          {% render 'subscribe_form', heading: 'Get new posts by email.' %}
          <p class="writing-rss-link">
            Or subscribe via <a href="{{ '/feed.xml' | relative_url }}" class="section-link">RSS</a>
          </p>
        </div>
        <div class="content-body">
          {{ content }}
        </div>
        <footer class="page-footer">
          <div class="page-signature">
            <div class="brand-shape-tiny"></div>
          </div>
        </footer>
      </main>
    </div>
    <!-- 100% privacy-first analytics -->
      <script async defer src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
      <noscript>
        <img src="https://queue.simpleanalyticscdn.com/noscript.gif" alt="" referrerpolicy="no-referrer-when-downgrade">
      </noscript>
      </body>
    </html>